top: tb

imports:
  dutlib: ./ideal_gm_go_gi_rc_cell.asdl
  ana: analoglib.asdl
  sim: simulation.xyce.asdl

modules:
  tb:
    variables:
      GM: 1e-3
      RO: 5k
      RI: 10k
      COUT: 1p
      CIN: 1p
      AC_POINTS: 200
      AC_START: 1
      AC_STOP: 1e11
    instances:
      dut: dutlib.ideal_gm_go_gi_rc_cell gm={GM} ro={RO} ri={RI} cout={COUT} cin={CIN}

      vinp: ana.vac dc=0 ac_mag=0 ac_phase=0
      vtest: ana.vac dc=0 ac_mag=1 ac_phase=0
      itest: ana.iac dc=0 ac_mag=0 ac_phase=0

      ac1: sim.ac sweep_type=DEC points={AC_POINTS} start_freq={AC_START} end_freq={AC_STOP}
      save_ac: sim.save sim_type=AC signals='V(*) I(*)'

    nets:
      inp: [vinp.p, dut.inp]
      out_side: [dut.out, vtest.p, itest.p]
      inn_side: [dut.inn, vtest.n, itest.n]
      '0': [vinp.n, dut.vss]
